# ============================================================
# .env.example — CourseHub SaaS Platform
# Copy to .env.local and fill in your values
# cp .env.example .env.local
# ============================================================

# MongoDB
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=saas-cursos

# AWS S3 / Rustfs (S3-compatible object storage)
AWS_USERNAME=your-rustfs-access-key
AWS_PASSWORD=your-rustfs-secret-key
AWS_REGION=us-east-1
AWS_URL=http://localhost:10000
AWS_BUCKET=saas-cursos-bucket

# Email (Mailhog in development)
MAILHOG_HOST=localhost
MAIL_PORT=1027

# Next.js
NODE_ENV=development
NEXT_PUBLIC_API_URL=http://localhost:3000

# JWT (use a strong random string in production — min 32 chars)
JWT_SECRET=your-jwt-secret-here
